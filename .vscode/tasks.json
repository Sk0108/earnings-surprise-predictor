{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate Demo Data",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts\\generate_demo_data.py"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Train Model",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts\\train_model.py",
        "--demo"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Run Streamlit Dashboard",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "streamlit",
        "run",
        "app.py"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
